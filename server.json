{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.misterwigglesworth/easy-notion",
  "description": "Markdown-first Notion MCP server — 87% fewer tokens, 26 tools, round-trip fidelity.",
  "repository": {
    "url": "https://github.com/Grey-Iris/easy-notion-mcp",
    "source": "github"
  },
  "version": "0.2.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "easy-notion-mcp",
      "version": "0.2.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "NOTION_TOKEN",
          "description": "Notion integration token",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "NOTION_ROOT_PAGE_ID",
          "description": "Root page ID that scopes the server's access",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
